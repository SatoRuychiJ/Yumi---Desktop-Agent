<UserControl x:Class="VPet_Simulator.Core.ToolBar" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ll="clr-namespace:LinePutScript.Localization.WPF;assembly=LinePutScript.Localization.WPF"
        xmlns:local="clr-namespace:VPet_Simulator.Core" xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pu="https://opensource.panuon.com/wpf-ui" Width="500" Height="500" VerticalAlignment="Top"
        MouseEnter="UserControl_MouseEnter" MouseLeave="UserControl_MouseLeave" mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
                <ResourceDictionary Source="basestyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="MainGrid" x:FieldModifier="public">
        <Border x:Name="BdrPanel" Margin="20,130,20,55" VerticalAlignment="Stretch" x:FieldModifier="public"
                Background="{DynamicResource Primary}" BorderBrush="{DynamicResource DARKPrimaryDark}"
                BorderThickness="2" CornerRadius="8" MouseLeave="MenuPanel_MouseLeave" TextBlock.FontSize="24"
                TextElement.FontSize="24" TextElement.FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                Visibility="Collapsed" Cursor="" d:Visibility="Visible">
            <Grid Margin="15" x:Name="gdPanel" x:FieldModifier="public">
                <!-- AIDeskPet: 等级/金钱/状态条已全部移除, 面板 = AI 用量统计 (由 AIPet 插件填充) -->
                <StackPanel x:Name="spAIStats" x:FieldModifier="public" MinWidth="300" MinHeight="60" />
            </Grid>
        </Border>
        <Menu x:Name="ToolBarMenu" Width="500" VerticalAlignment="Bottom" pu:MenuHelper.SubmenuItemsHorizontalContentAlignment="Center"
                pu:MenuHelper.TopLevelItemsHorizontalContentAlignment="Center"
                Style="{DynamicResource ToolBarMenuStyle}" ScrollViewer.VerticalScrollBarVisibility="Auto"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled" pu:DropDownHelper.Width="NaN"
                pu:DropDownHelper.MaxHeight="500" Height="60">
            <Menu.Tag>
                <system:Int32>3</system:Int32>
            </Menu.Tag>
            <Menu.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding Tag, ElementName=ToolBarMenu}" />
                </ItemsPanelTemplate>
            </Menu.ItemsPanel>
            <!-- AIDeskPet: 投喂系统已移除 -->
            <MenuItem x:Name="MenuFeed" Padding="0" x:FieldModifier="public" Header="🍔投喂" Visibility="Collapsed" />
            <MenuItem x:Name="MenuPanel" Padding="0" Header="📊 Usage" Foreground="{DynamicResource DARKPrimary}"
                    MouseEnter="MenuPanel_MouseEnter" MouseLeave="MenuPanel_MouseLeave" />
            <MenuItem x:Name="MenuInteract" Padding="0" Header="🎮互动" Foreground="{DynamicResource DARKPrimary}" Visibility="Collapsed" x:FieldModifier="public">
                <MenuItem x:Name="MenuStudy" Header="{ll:Str 学习}" Visibility="Collapsed" ScrollViewer.VerticalScrollBarVisibility="Auto"
                        pu:DropDownHelper.MaxHeight="100" x:FieldModifier="public" />
                <MenuItem x:Name="MenuPlay" Header="{ll:Str 玩耍}" ScrollViewer.VerticalScrollBarVisibility="Auto"
                        pu:DropDownHelper.MaxHeight="100" x:FieldModifier="public" />
                <MenuItem x:Name="MenuWork" Header="{ll:Str 工作}" ScrollViewer.VerticalScrollBarVisibility="Auto"
                        pu:DropDownHelper.MaxHeight="100" x:FieldModifier="public" />
                <!--<MenuItem Header="说话"  IsEnabled="False" />-->
            </MenuItem>
            <MenuItem x:Name="MenuDIY" Padding="0" x:FieldModifier="public" Header="🧩 DIY" Foreground="{DynamicResource DARKPrimary}" />
            <MenuItem x:Name="MenuSetting" Padding="0" x:FieldModifier="public" Header="⚙️ System" Foreground="{DynamicResource DARKPrimary}">
                <MenuItem x:Name="MenuMODConfig" x:FieldModifier="public" Header="{ll:Str MOD设置}" Visibility="Collapsed" />
            </MenuItem>
        </Menu>
    </Grid>
</UserControl>
